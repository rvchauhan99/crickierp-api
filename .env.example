# Copy to `.env` — Node only loads `.env`, not this file.
NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/crickierp
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
# Comma-separated allowlist (spaces optional): all listed origins are allowed.
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Email (optional)
BREVO_USER=
BREVO_MASTER_KEY=
BREVO_FROM=noreply@crickierp.local

# Bucket storage (required for document uploads)
BUCKET_ENDPOINT=
BUCKET_NAME=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
BUCKET_REGION=auto
BUCKET_PUBLIC_URL_BASE=

# Mongo performance tuning
MONGO_MAX_POOL_SIZE=80
MONGO_MIN_POOL_SIZE=10
MONGO_MAX_CONNECTING=8
MONGO_WAIT_QUEUE_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Observability and performance gates
ENABLE_MONGO_SLOW_QUERY_LOG=true
MONGO_SLOW_QUERY_MS=120
ENABLE_PERFORMANCE_METRICS=true
API_P95_WARN_MS=500

# Redis (required to enable cache and BullMQ queue workers)
REDIS_URL=rediss://default:<upstash-token>@<upstash-host>:6379
