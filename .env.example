# Copy to `.env` — Node only loads `.env`, not this file.
NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/crickierp
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
# Comma-separated allowlist (spaces optional): all listed origins are allowed.
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Email (optional)
BREVO_USER=
BREVO_MASTER_KEY=
BREVO_FROM=noreply@crickierp.local

# Bucket storage (required for document uploads)
BUCKET_ENDPOINT=
BUCKET_NAME=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
BUCKET_REGION=auto
BUCKET_PUBLIC_URL_BASE=
